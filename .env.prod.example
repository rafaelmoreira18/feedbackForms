JWT_EXPIRES_IN=1d
CORS_ORIGINS=https://mediallquality.com,https://www.mediallquality.com

# Database - Pesquisa_Satisfacao_Paciente_DB (formulários, respostas, treinamentos)
# IMPORTANTE: use o usuario feedbackforms_app (permissoes minimas), nao o superadmin postgres.
# Execute backend/src/database/migrations/create-app-user-permissions.sql para criar o usuario.
DB_HOST=dbpgpesquisamkt.ce6ipyxrb0gc.sa-east-1.rds.amazonaws.com
DB_PORT=5432
DB_USERNAME=feedbackforms_app
DB_PASSWORD=sua-senha-gerada
DB_DATABASE=Pesquisa_Satisfacao_Paciente_DB
DB_SYNCHRONIZE=false
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true

# Database - Autenticacao_DB (tenants + usuarios — compartilhado entre sistemas)
# IMPORTANTE: use o usuario feedbackforms_app (permissoes minimas), nao o superadmin postgres.
AUTH_DB_HOST=dbpgpesquisamkt.ce6ipyxrb0gc.sa-east-1.rds.amazonaws.com
AUTH_DB_PORT=5432
AUTH_DB_USERNAME=feedbackforms_app
AUTH_DB_PASSWORD=sua-senha-gerada
AUTH_DB_DATABASE=Autenticacao_DB
AUTH_DB_SSL=true
AUTH_DB_SSL_REJECT_UNAUTHORIZED=true
