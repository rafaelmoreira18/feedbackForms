PORT=3001
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=1d

# Database - feedbackforms (formulários, templates, respostas)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=feedbackforms
DB_SYNCHRONIZE=false
DB_SSL=false

# Database - Multi_UnidadesDB (autenticação de usuários)
# Pode apontar para o mesmo host/servidor RDS
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5432
AUTH_DB_USERNAME=your_db_user
AUTH_DB_PASSWORD=your_db_password
AUTH_DB_DATABASE=Multi_UnidadesDB
AUTH_DB_SSL=false

CORS_ORIGINS=http://localhost:5173
NODE_ENV=development
